# Database (Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres?search_path=readmax

# WebAuthn / Passkey Auth
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGIN=http://localhost:5173

# Admin API
ADMIN_API_TOKEN=

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=

# Redis (resumable chat streaming)
# Required in production. In dev, chat streaming falls back gracefully if unset.
# Vercel KV, Upstash, or any Redis-compatible URL works.
REDIS_URL=
